# ============================================================
# DomiLink - Variables de entorno
# Copiar este archivo a .env y ajustar los valores
# NUNCA subir .env a git
# ============================================================

# JWT - CAMBIAR EN PRODUCCION (minimo 256 bits / 32 caracteres)
JWT_SECRET=domilink-super-secret-key-2024-change-in-production-minimum-256-bits
JWT_EXPIRATION=86400000

# Firebase - Dejar vacio para desarrollo local sin Firebase
# En produccion: usar Google Secret Manager
FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=domilink-dev

# Configuracion de precios (COP - Pesos Colombianos)
PRICING_BASE_PRICE=3000.0
PRICING_PRICE_PER_KM=1500.0
PRICING_MINIMUM_PRICE=5000.0
PRICING_MAXIMUM_PRICE=80000.0
